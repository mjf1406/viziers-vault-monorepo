{
  "name": "electron",
  "version": "0.0.1",
  "description": "Vizier's Vault desktop app (Electron)",
  "author": "Vizier's Vault",
  "type": "commonjs",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node build-main.mjs",
    "dev": "pnpm exec turbo run build --filter=web --filter=electron... && electron .",
    "package": "electron-builder",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@hono/node-server": "^1.13.7",
    "@workspace/api": "workspace:*",
    "@workspace/db": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "web": "workspace:*"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  }
}
