# Database (required)
DATABASE_URL=postgres://user:password@localhost:5432/viziers_vault

# Deployment: "cloud" (email + Google OAuth) or "self-host" (email only)
DEPLOYMENT_MODE=self-host

# Better Auth (required for web/self-host)
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
# In local dev with Vite proxy, use the Vite origin so cookies land on same origin
BETTER_AUTH_BASE_URL=http://localhost:5173

# Server
PORT=3000

# Optional: Google OAuth (cloud mode only; omit for self-host)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
