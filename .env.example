# Copy to .env and fill for local dev or self-host.
# Used by apps/server, packages/db, and (optionally) apps/web.

# Server (internal listen port)
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgres://localhost:5432/viziers_vault
# Or for Docker Compose postgres service:
# DATABASE_URL=postgres://viziers:YOUR_PASSWORD@localhost:5432/viziers_vault

# Better Auth (required by apps/server)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public app origin (browser-visible URL of the web app, not the server port).
# Better Auth uses this for cookie domain and redirect targets.
# Dev: web app at :3000, API proxied from /api → :3001.
# Production: set to your public domain (e.g. https://app.example.com).
APP_ORIGIN=http://localhost:3000

# Self-host Docker (when using docker-compose.selfhost.yml)
# POSTGRES_USER=viziers
# POSTGRES_PASSWORD=
# POSTGRES_DB=viziers_vault
# POSTGRES_PORT=5432

# Web app (optional; for API base URL in browser when not using same-origin proxy)
# VITE_API_BASE_URL=/api
