{
  "name": "vite-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web --filter=api",
    "dev:desktop": "turbo dev --filter=desktop",
    "dev:services": "docker compose -f docker/docker-compose.dev.yml up -d",
    "dev:stop": "docker compose -f docker/docker-compose.dev.yml down",
    "db:migrate": "pnpm --filter=@workspace/db run migrate",
    "db:studio": "pnpm --filter=@workspace/db run studio",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20"
  }
}