FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.0.6 --activate
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile

FROM base AS builder
COPY --from=deps /app/package.json --from=deps /app/pnpm-lock.yaml --from=deps /app/pnpm-workspace.yaml ./
COPY apps/web ./apps/web
COPY packages/ui/package.json packages/ui/tsconfig.json packages/ui/components.json ./packages/ui/
COPY packages/ui/src ./packages/ui/src
COPY packages/ui/src/styles ./packages/ui/src/styles
COPY packages/shared/package.json packages/shared/tsconfig.json ./packages/shared/
COPY packages/shared/src ./packages/shared/src
RUN pnpm install --frozen-lockfile
WORKDIR /app
RUN pnpm --filter=web build

FROM nginx:alpine AS runner
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
